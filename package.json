{
  "name": "scout-mobile",
  "version": "0.3.0",
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build --noEmit",
    "test:integration": "npm run test:integration:ios && npm run test:integration:android",
    "test:integration:ios": "vitest run --config packages/platform-ios/vitest.integration.config.ts",
    "test:integration:android": "npm run test:integration -w @scout-mobile/platform-android",
    "pack:check": "npm run build && npm pack --dry-run --workspaces"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "fast-uri": "^3.1.2"
  }
}
