{
  "name": "scout-mobile",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build --noEmit",
    "test:integration": "vitest run --config packages/platform-ios/vitest.integration.config.ts",
    "pack:check": "npm run build && npm pack --dry-run --workspaces"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
